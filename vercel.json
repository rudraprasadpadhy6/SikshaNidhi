{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "50mb"
      }
    },
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.py"
    },
    {
      "src": "/dashboard",
      "dest": "/frontend/dashboard.html"
    },
    {
      "src": "/login",
      "dest": "/frontend/login.html"
    },
    {
      "src": "/scholar",
      "dest": "/frontend/index1.html"
    },
    {
      "src": "/capital",
      "dest": "/frontend/index2.html"
    },
    {
      "src": "/pixa",
      "dest": "/frontend/PixaBot.html"
    },
    {
      "src": "/admin",
      "dest": "/frontend/feedback_admin.html"
    },
    {
      "src": "/(.*\\.(html|css|js|jpeg|jpg|png|mp4|ico|svg))",
      "dest": "/frontend/$1"
    },
    {
      "src": "/",
      "dest": "/frontend/login.html"
    }
  ]
}
